# Copy to `.env` and fill in. `.env` is gitignored.

# --- Auth (pick one) ---
# Local dev without Microsoft Entra: skip sign-in (fixed user `local-dev`, group `admin`)
# AUTH_MODE=disabled
# Production: OIDC (set AZURE_* vars below; do not use AUTH_MODE=disabled)
# AUTH_MODE=oidc

# --- Local Ollama (default) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=gemma4:latest
